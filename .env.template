# Required for the default OpenClaw deploy
OPENAI_API_KEY=

# Optional. Only set this if you switch away from the default OpenAI model.
ANTHROPIC_API_KEY=

# Optional. Default deploys use OpenAI GPT-5.4.
OPENCLAW_PROVIDER_MODEL=openai/gpt-5.4

# Optional. Only set this if you want to override the internal gateway token.
OPENCLAW_GATEWAY_TOKEN=

# Optional app auth token for FastAPI routes
APP_TOKEN=
